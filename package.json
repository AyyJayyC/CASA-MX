{
  "name": "casa-mx",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18 <=20"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev -w apps/web\" \"npm run dev -w apps/api\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build -w packages/shared && npm run build -w apps/api && npm run build -w apps/web",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:shared": "npm run build -w packages/shared",
    "test": "npm run test -w apps/web --if-present && npm run test -w apps/api --if-present",
    "test:web": "npm run test -w apps/web",
    "test:api": "npm run test -w apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "rimraf apps/*/node_modules packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.10"
  }
}
