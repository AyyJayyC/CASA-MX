{
  "name": "casa-mx-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node scripts/check-node-version.js && next dev -p 3000",
    "build": "node scripts/check-node-version.js && next build",
    "start": "node scripts/check-node-version.js && next start",
    "test": "node scripts/run-with-timeout.js vitest run --no-coverage",
    "test:coverage": "node scripts/run-with-timeout.js vitest run --coverage",
    "test:coverage:e2e": "node scripts/collect-e2e-coverage.js",
    "test:coverage:full": "node scripts/full-coverage.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:upload:headed": "playwright test tests/e2e/publish-upload-live.spec.ts --headed",
    "test:e2e:auto": "start-server-and-test 'npm run dev' http://localhost:3000 'npm run test:e2e'",
    "lint": "next lint",
    "test:browser": "vitest --config vitest.browser.config.js run",
    "benchmark": "node scripts/benchmark.js",
    "metrics": "npx unentropy init"
  },
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "^2.19.3",
    "@hookform/resolvers": "^3.1.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^1.2.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.7.0",
    "next": "^15.5.14",
    "nuqs": "^2.8.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.45.0",
    "recharts": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.9",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.17.6",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/browser": "^3.2.6",
    "@vitest/coverage-istanbul": "^3.2.6",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.14",
    "babel-plugin-istanbul": "^8.0.0",
    "benchmark": "^2.1.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^22.1.0",
    "nyc": "^18.0.0",
    "playwright": "^1.41.0",
    "postcss": "^8.5.15",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^4.3.1",
    "v8-to-istanbul": "^9.3.0",
    "vitest": "^3.2.4",
    "vitest-browser-react": "^1.0.1"
  }
}
