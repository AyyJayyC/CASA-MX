{
  "name": "casa-mx-v2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:encoding && next build",
    "start": "next start",
    "lint": "next lint",
    "check:encoding": "node -e \"const fs=require('fs');const bad=[];fs.readdirSync('src',{recursive:true}).filter(f=>f.match(/\\.(tsx|ts|css)$/)).forEach(f=>{const p='src/'+f;const b=fs.readFileSync(p);if(b[0]===0xEF&&b[1]===0xBB&&b[2]===0xBF)bad.push(p)});if(bad.length){console.error('BOM found in:',bad.join(', '));process.exit(1)}else console.log('Encoding OK')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.50.0",
    "axios": "^1.7.0",
    "maplibre-gl": "^5.24.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.52.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.4.0",
    "sharp": "^0.35.1",
    "@emnapi/core": "^1.11.0",
    "@emnapi/runtime": "^1.11.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
