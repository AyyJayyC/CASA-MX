{
  "metrics": {
    "lines-of-code": {
      "$ref": "loc",
      "name": "Lines of Code",
      "command": "@collect loc ./src --language TypeScript"
    },
    "test-coverage": {
      "$ref": "coverage",
      "name": "Test Coverage",
      "command": "@collect coverage-lcov coverage/lcov.info"
    },
    "bundle": {
      "$ref": "size",
      "name": "Bundle Size",
      "command": "@collect size dist"
    }
  },
  "storage": {
    "type": "sqlite-artifact"
  },
  "qualityGate": {
    "mode": "soft",
    "thresholds": [
      {
        "metric": "test-coverage",
        "mode": "min",
        "target": 80,
        "severity": "warning"
      }
    ]
  }
}
