# Application Environment
NODE_ENV=development
PORT=3001

# Database Configuration
# ⚠️ REQUIRED: Use separate environment variables for docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/casamx?schema=public"

# Redis Configuration (Optional but recommended for caching)
# ⚠️ REQUIRED for docker-compose: Redis auth password
REDIS_PASSWORD=redis
# Format: redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://:redis@localhost:6379

# JWT Authentication
# ⚠️ REQUIRED: Use openssl rand -base64 32 to generate secure random string (min 32 chars)
# ⚠️ PRODUCTION: MUST change from default value
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# ⚠️ OPTIONAL: Separate secret for refresh tokens (recommended for production)
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Frontend Configuration
# ⚠️ REQUIRED: Frontend URL for CORS configuration
# ⚠️ PRODUCTION: Must be your actual domain (e.g., https://casamx.com)
FRONTEND_URL=http://localhost:3000

# Google Maps API
# ⚠️ REQUIRED: Get API key from https://console.cloud.google.com/apis/credentials
# ⚠️ PRODUCTION: Use a server-side key with appropriate backend restrictions and API quotas
MAPS_API_KEY=your-google-maps-api-key
# REQUIRED for Google-backed autocomplete/geocode in Casa MX.
ENABLE_BILLABLE_MAPS=true

# Optional: Monitoring & Error Tracking (Uncomment to enable)
# SENTRY_DSN=https://...your-sentry-dsn...
# LOGR_OCKET_APP_ID=...your-logrocket-id...
# DATADOG_API_KEY=...your-datadog-key...

# AWS S3 (for property images and document uploads)
# ⚠️ REQUIRED for image/document upload: Get credentials from AWS IAM
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET=casamx-uploads
AWS_REGION=us-east-1

# ─── Railway Production Deployment ─────────────────────────────────
# Set these in the Railway dashboard (not in .env):
#
#   POSTGRES_USER       — Database username (replaces hardcoded 'postgres')
#   POSTGRES_PASSWORD   — Database password (replaces hardcoded 'postgres')
#   REDIS_PASSWORD      — Redis auth password (replaces default 'redis')
#   DATABASE_URL        — Full PostgreSQL connection string
#   REDIS_URL           — Full Redis connection string with password
#   JWT_SECRET          — Min 32 chars, use openssl rand -base64 32
#   FRONTEND_URL        — https://casa-mx.com (or your Vercel domain)
#   ADMIN_EMAIL         — Email that gets auto-approved admin + all roles (e.g. 5axelj@gmail.com)
#   MIGRATION_SECRET    — Secret for admin setup/bootstrap endpoints
#   STRIPE_SECRET_KEY   — From Stripe dashboard
#   STRIPE_WEBHOOK_SECRET — From Stripe dashboard
#   RESEND_API_KEY      — From Resend dashboard
#   RESEND_FROM_EMAIL=noreply@casa-mx.com — Must match a verified domain in Resend
#   RESEND_FROM_NAME=CasaMX
#   SENTRY_DSN          — From Sentry dashboard (optional but recommended)
#   AWS_*               — From AWS IAM
#   GOOGLE_CLIENT_ID    — From Google Cloud Console
#   GOOGLE_CLIENT_SECRET — From Google Cloud Console
#   MAPS_API_KEY        — From Google Cloud Console
#
# The docker-compose.yml now references ${POSTGRES_USER},
# ${POSTGRES_PASSWORD}, ${REDIS_PASSWORD} env vars — these MUST
# be set in Railway before deploying, or the container will fail.
# ─────────────────────────────────────────────────────────────────
