generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String?  // null for OAuth-only users
  provider  String?  // google | facebook | apple | null (email/password)
  providerId String? // OAuth provider's user ID
  avatarUrl String?  // profile picture from OAuth provider
  phone     String?  // contact phone number (optional)
  whatsapp  String?  // WhatsApp number with country code, e.g. +525512345678
  rfc       String?  // Mexican tax ID (RFC)
  razonSocial String? // legal/business name for invoices
  usoCFDI   String?  // CFDI usage code for invoices (G03, D01, etc.)
  emailVerified     Boolean  @default(false)
  phoneVerified     Boolean  @default(false)
  pendingEmail      String?  // email que el usuario quiere cambiar, pendiente de verificar
  verificationToken String?  @unique
  verificationTokenExpiresAt DateTime?
  passwordResetToken          String?  @unique
  passwordResetTokenExpiresAt DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastFailedLoginAt   DateTime?
  roles              UserRole[]
  reviewsWritten     Review[] @relation("ReviewAuthor")
  reviewsReceived    Review[] @relation("ReviewTarget")
  creditBalance      CreditBalance?
  creditTransactions CreditTransaction[]
  listedProperties   Property[] @relation("PropertySeller")
  uploadedDocuments  PropertyDocument[] @relation("DocumentUploader")
  userDocuments      UserDocument[]     @relation("UserDocuments")

  // Referral system
  referralCode   String?  @unique
  referredById   String?
  referredBy     User?    @relation("ReferralChain", fields: [referredById], references: [id])
  referrals      User[]   @relation("ReferralChain")

  // Agency membership
  agencyId         String?
  agency           Agency?  @relation("AgencyMembers", fields: [agencyId], references: [id])
  ownedAgency      Agency?  @relation("AgencyOwner")
  agenciesReferred Agency[] @relation("AgencyReferrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId])
  @@index([email])
  @@index([provider])
  @@index([verificationToken])
  @@index([passwordResetToken])
  @@index([referralCode])
  @@index([referredById])
  @@index([agencyId])
  @@index([createdAt])
}

model Agency {
  id             String   @id @default(uuid())
  name           String
  legalName      String?
  rfc            String?
  ownerId        String   @unique
  owner          User     @relation("AgencyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  referredById   String?
  referredBy     User?    @relation("AgencyReferrals", fields: [referredById], references: [id])
  referralCode   String   @unique
  members        User[]   @relation("AgencyMembers")

  // Subscription plan
  plan           String   @default("inactive") // inactive | basico | pro | empresarial
  agentLimit     Int      @default(0)  // max agents allowed
  billingActive  Boolean  @default(false)
  subscriptionEnds DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@index([referredById])
  @@index([referralCode])
  @@index([plan])
  @@index([billingActive, subscriptionEnds])
}

model Role {
  id    String   @id @default(uuid())
  name  String   @unique // buyer, seller, wholesaler, admin
  createdAt DateTime @default(now())

  userRoles UserRole[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  status    String   @default("pending") // pending, approved, denied
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([status])
}

model Property {
  id          String   @id @default(uuid())
  title       String
  description String?
  address     String?
  imageUrls   String[] @default([])
  price       Float?   // Optional now - required only for sales
  lat         Float?
  lng         Float?
  status      String   @default("disponible") // disponible, preventa, vendido, rentado, etc
  estado      String   @default("Ciudad de México") // Mexican state (required)
  ciudad      String?  // City/Municipality (e.g., Guadalajara, Monterrey)
  colonia     String?  // Neighborhood (e.g., Roma Norte, Polanco)
  codigoPostal String? // ZIP code (e.g., 06700, 44100)
  propertyType String?
  bedrooms    Int?
  bathrooms   Int?
  squareMeters Int?
  includedServices String[] @default([])
  amenities   String[] @default([])
  financeOptions String[] @default([])  // cash, bankLoan, INFONAVIT, FOVISSSTE, paymentPlan, other
  sellerId    String
  seller      User     @relation("PropertySeller", fields: [sellerId], references: [id])
  
  // Ownership verification
  verificationStatus String  @default("unverified") // unverified | docs_uploaded | verified | rejected
  verificationNote   String? @db.Text
  
  // Rental system fields
  listingType       String   @default("for_sale") // for_sale, for_rent
  monthlyRent       Float?   // Required for rentals
  securityDeposit   Float?   // Typically 1-2 months rent
  leaseTermMonths   Int?     // 6, 12, 24 months
  availableFrom     DateTime?
  furnished         String?   // unfurnished, semi_furnished, furnished, equipada
  utilitiesIncluded Boolean  @default(false)
  
  // Extended property details (Casa MX v2)
  condition        String?   // new, remodeled, needs_remodeling, good
  parkingType      String?   // none, garage, driveway, street, covered
  parkingSpaces    Int?      // number of parking spots
  miniSplits       Int?      // number of mini split units
  petFriendly      Boolean   @default(false)
  petFee           Float?    // monthly pet fee
  petDeposit       Float?   // one-time pet deposit
  yearBuilt        Int?      // construction year
  floors           Int?      // number of floors
  lotSize          Int?      // land/lot size in m²
  maintenanceFee   Float?    // monthly HOA/maintenance fee
  halfBaths        Int?      // powder rooms
  childrenWelcome  Boolean   @default(false)
  issuesInvoice    Boolean   @default(false)
  visibility       String    @default("public")  // public, private
  mapsUrl           String?   // Google Maps embed URL
  inventoryNotes    String?   @db.Text // inventory notes for contracts
  
  // Promotion / visibility tiers
  promotionTier String?  // null = none, "featured" = Destacado, "carousel" = Promocionado
  featuredUntil DateTime? // when the promotion expires
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propertyRequests   PropertyRequest[]
  rentalApplications RentalApplication[]
  reviews            Review[]
  propertyOffers     PropertyOffer[]
  documents          PropertyDocument[]
  images             PropertyImage[]

  @@index([sellerId])
  @@index([status])
  @@index([price])
  @@index([estado])
  @@index([ciudad])
  @@index([colonia])
  @@index([codigoPostal])
  @@index([listingType])
  @@index([promotionTier])
  @@index([featuredUntil])
  @@index([createdAt])
  @@index([furnished])
  @@index([visibility])
  @@index([monthlyRent])
}

model PropertyDocument {
  id           String   @id @default(uuid())
  propertyId   String
  uploaderId   String
  documentType String   // title_deed | official_id | agent_authorization | other
  fileUrl      String   // S3 key (not public URL)
  fileName     String
  fileMimeType String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  uploader     User     @relation("DocumentUploader", fields: [uploaderId], references: [id])
  createdAt    DateTime @default(now())

  @@index([propertyId])
  @@index([uploaderId])
}

model UserDocument {
  id           String   @id @default(uuid())
  userId       String
  documentType String   // official_id | other
  fileUrl      String   // S3 key (not public URL)
  fileName     String
  fileMimeType String
  isVerified   Boolean  @default(false)
  reviewStatus String?   // pending | approved | rejected
  reviewNote   String?
  user         User     @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([documentType])
}

model PropertyRequest {
  id         String   @id @default(uuid())
  propertyId String
  buyerId    String
  name       String?  // buyer's name for contact
  phone      String?  // buyer's phone for contact
  message    String?
  status     String   @default("pending") // pending, contacted
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([propertyId, buyerId])
  @@index([propertyId])
  @@index([buyerId])
  @@index([status])
}

model RentalApplication {
  id          String   @id @default(uuid())
  propertyId  String
  applicantId String
  status      String   @default("pending") // pending, under_review, approved, rejected, withdrawn, expired
  
  // Personal Information
  fullName    String
  email       String
  phone       String
  
  // Employment Information
  employer           String
  jobTitle           String
  monthlyIncome      Float
  employmentDuration String
  
  // Rental Preferences
  desiredMoveInDate  DateTime
  desiredLeaseTerm   Int      // 6, 12, 24 months
  numberOfOccupants  Int
  
  // References
  reference1Name     String
  reference1Phone    String
  reference2Name     String?
  reference2Phone    String?
  
  // Additional
  messageToLandlord   String?  @db.Text
  landlordNote        String?  @db.Text
  offeredMonthlyRent  Float?
  
  // Document URLs (structure for Phase 6)
  idDocumentUrl      String?
  incomeProofUrl     String?
  additionalDocsUrls String[]
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reviews Review[]
  
  @@index([propertyId])
  @@index([applicantId])
  @@index([status])
  @@index([createdAt])
  @@unique([propertyId, applicantId])
}

model Review {
  id                  String   @id @default(uuid())
  reviewerUserId      String
  revieweeUserId      String
  reviewerRole        String
  revieweeRole        String
  propertyId          String
  rentalApplicationId String
  overallRating       Int
  comment             String?  @db.Text
  status              String   @default("published") // published, flagged, hidden
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  reviewer          User              @relation("ReviewAuthor", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  reviewee          User              @relation("ReviewTarget", fields: [revieweeUserId], references: [id], onDelete: Cascade)
  property          Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rentalApplication RentalApplication @relation(fields: [rentalApplicationId], references: [id], onDelete: Cascade)

  @@unique([reviewerUserId, revieweeUserId, rentalApplicationId])
  @@index([revieweeUserId, revieweeRole, status])
  @@index([reviewerUserId, reviewerRole])
  @@index([propertyId])
  @@index([rentalApplicationId])
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  type       String   // rental_application_received, application_status_changed, etc.
  title      String
  message    String   @db.Text
  entityType String?  // property, application, etc.
  entityId   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  
  @@index([userId, read])
  @@index([createdAt])
}

model ReferralEvent {
  id             String   @id @default(uuid())
  referrerId     String?
  referralCode   String
  eventType      String   // click | signup | conversion
  propertyId     String?
  linkedUserId   String?
  visitorIp      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([referralCode])
  @@index([referrerId])
  @@index([eventType])
  @@index([createdAt])
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  eventName  String
  userId     String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([eventName])
  @@index([userId])
  @@index([createdAt])
  @@index([eventName, entityId])
}

model AuditLog {
  id             String   @id @default(uuid())
  actorUserId    String
  targetUserId   String?
  action         String   // APPROVE_ROLE, DENY_ROLE, CREATE_PROPERTY, etc.
  previousState  Json?
  newState       Json?
  createdAt      DateTime @default(now())

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

// Debug/Logging Models - Checkpoint 1

model DebugSession {
  id                String   @id @default(uuid())
  userId            String?
  userEmail         String?
  sessionStartTime  DateTime @default(now())
  sessionEndTime    DateTime?
  initialRoute      String
  userAgent         String?
  ipAddress         String?
  hasErrors         Boolean  @default(false)
  exported          Boolean  @default(false)
  exportedAt        DateTime?
  createdAt         DateTime @default(now())

  actionLogs        ActionLog[]
  errorLogs         ErrorLog[]
  apiLogs           ApiLog[]

  @@index([userId])
  @@index([userEmail])
  @@index([hasErrors])
  @@index([exported])
  @@index([sessionStartTime])
  @@index([createdAt])
}

model ActionLog {
  id                String   @id @default(uuid())
  sessionId         String
  userId            String?
  userEmail         String?
  actionType        String   // button_click, form_submit, navigation, api_call, etc.
  actionName        String   // upload_property_submit, login_button_click, etc.
  componentName     String?
  currentRoute      String
  metadata          Json?
  userAgent         String?
  timestamp         DateTime @default(now())
  createdAt         DateTime @default(now())

  session           DebugSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([actionType])
  @@index([timestamp])
  @@index([createdAt])
}

model ErrorLog {
  id                String   @id @default(uuid())
  sessionId         String
  userId            String?
  userEmail         String?
  errorType         String   // frontend, backend, api, database, validation
  errorMessage      String   @db.Text
  errorStackTrace   String?  @db.Text
  errorCode         String?
  severity          String   // low, medium, high, critical
  componentName     String?
  currentRoute      String
  contextData       Json?
  resolved          Boolean  @default(false)
  resolvedAt        DateTime?
  resolvedById      String?
  resolvedNote      String?  @db.Text
  timestamp         DateTime @default(now())
  createdAt         DateTime @default(now())

  session           DebugSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([errorType])
  @@index([severity])
  @@index([resolved])
  @@index([timestamp])
  @@index([createdAt])
}

model ApiLog {
  id                String   @id @default(uuid())
  sessionId         String
  userId            String?
  httpMethod        String   // GET, POST, PATCH, DELETE, etc.
  apiEndpoint       String
  requestHeaders    Json?
  requestBody       Json?
  responseStatus    Int
  responseBody      Json?
  responseTimeMs    Int
  errorMessage      String?  @db.Text
  timestamp         DateTime @default(now())
  createdAt         DateTime @default(now())

  session           DebugSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([apiEndpoint])
  @@index([responseStatus])
  @@index([timestamp])
  @@index([createdAt])
}

// Maps usage tracking models (Checkpoint 2)

model ApiUsageLog {
  id              String   @id @default(uuid())
  provider        String   // e.g., "google_maps", "nominatim"
  serviceType     String   // e.g., "tile_request", "geocoding", "places_autocomplete", "directions"
  requestTimestamp DateTime @default(now())
  userId          String?
  requestDetails  Json?
  responseStatus  String   // success, rate_limited, error
  responseTimeMs  Int?
  cost            Float?   // estimated cost for the request
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([serviceType])
  @@index([requestTimestamp])
  @@index([userId])
  @@index([responseStatus])
}

model UsageLimit {
  id           String   @id @default(uuid())
  serviceType  String   @unique
  limitType    String   // monthly, daily, rate
  limitValue   Int
  currentUsage Int      @default(0)
  resetAt      DateTime?
  alertThreshold Int    @default(80)
  hardStop     Boolean  @default(false)
  status       String   @default("active")
  createdAt    DateTime @default(now())

  @@index([serviceType])
  @@index([status])
}

model LimitAlert {
  id               String   @id @default(uuid())
  serviceType      String
  alertType        String   // threshold, limit_exceeded, hard_stop
  thresholdPercent Int
  usageAtAlert     Int
  limitValue       Int
  adminNotified    Boolean  @default(false)
  alertTimestamp   DateTime @default(now())
  resolved         Boolean  @default(false)

  @@index([serviceType])
  @@index([alertType])
  @@index([resolved])
}

// Credits / Payments models

model CreditBalance {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0) // credits available (1 credit = 1 MXN contact unlock)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CreditTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String   // purchase, spend, refund, bonus
  amount      Int      // positive = credit added, negative = credit deducted
  description String
  referenceId String?  // propertyId, applicationId, stripePaymentIntentId, etc.
  stripePaymentIntentId String? @unique
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceId])
}

model CreditPackage {
  id          String   @id @default(uuid())
  name        String   // e.g., "Starter", "Pro", "Enterprise"
  credits     Int      // number of credits in package
  priceMXN    Float    // price in MXN pesos
  stripePriceId String? // Stripe Price ID (optional, for hosted checkout)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

// Rent Negotiation models

model Negotiation {
  id                  String   @id @default(uuid())
  rentalApplicationId String   @unique  // one active negotiation per application
  propertyId          String
  applicantId         String
  landlordId          String
  status              String   @default("open") // open | accepted | rejected | expired
  originalRent        Float
  finalRent           Float?   // set when accepted
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  offers NegotiationOffer[]

  @@index([rentalApplicationId])
  @@index([applicantId])
  @@index([landlordId])
  @@index([status])
}

model NegotiationOffer {
  id              String   @id @default(uuid())
  negotiationId   String
  authorId        String   // userId of the person making the offer
  authorRole      String   // tenant | landlord
  proposedRent    Float
  message         String?  @db.Text
  status          String   @default("pending") // pending | accepted | rejected | countered
  createdAt       DateTime @default(now())

  negotiation Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@index([negotiationId])
  @@index([authorId])
  @@index([createdAt])
}

// Purchase offers on sale properties
model PropertyOffer {
  id             String   @id @default(uuid())
  propertyId     String
  buyerId        String
  status         String   @default("pending") // pending | accepted | rejected | countered
  
  // Offer details
  offerAmount    Float
  financing      String   // cash | bankLoan | INFONAVIT | FOVISSSTE | paymentPlan | other
  closingDate    DateTime?
  message        String?  @db.Text
  
  // Buyer contact
  buyerName      String
  buyerEmail     String
  buyerPhone     String

  // Payment plan details (only when financing = paymentPlan)
  enganche       Float?   // down payment amount
  plazoMeses     Int?     // term in months
  cuotaMensual   Float?   // calculated monthly payment (no interest)
  
  // Seller response
  sellerNote     String?  @db.Text
  counterAmount  Float?   // set if seller counters
  
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([propertyId])
  @@index([buyerId])
  @@index([status])
  @@index([createdAt])
}

model PropertyImage {
  id           String   @id @default(uuid())
  propertyId   String
  imageUrl     String
  fileName     String
  fileMimeType String
  caption      String?
  order        Int      @default(0)
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([propertyId])
  @@index([propertyId, order])
}

model Buyer {
  id          String   @id @default(uuid())
  name        String
  phone       String?
  email       String?
  budgetMin   Float?
  budgetMax   Float?
  preferredZones String[] @default([])
  propertyType String?
  notes       String?  @db.Text
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model CarouselSlide {
  id         String   @id @default(uuid())
  imageUrl   String
  title      String
  subtitle   String?
  link       String
  buttonText String?  @default("Ver más")
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TagSubscription {
  id           String   @id @default(uuid())
  userId       String
  tagType      String   // 'ciudad' | 'colonia'
  tagName      String   // display: "Hermosillo"
  tagNormal    String   // normalized: "hermosillo"
  estado       String?
  notifyInApp  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, tagType, tagNormal])
  @@index([tagType, tagNormal])
  @@index([userId])
}
